# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE CONFIG (For Vercel/External Deployments)
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_PROJECT_ID="proton-core-ai"
VITE_FIREBASE_AUTH_DOMAIN="proton-core-ai.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="proton-core-ai.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="770674231164"
VITE_FIREBASE_APP_ID="1:770674231164:web:10476d47ce81ea56b486f9"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-01dfb83a-da41-4952-8647-6368b0e05d51"
