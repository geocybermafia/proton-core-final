{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "ka"] }
      },
      "required": ["uid", "email"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "User automation workflows",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Persona": {
      "title": "Persona",
      "description": "AI Personality settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "systemInstruction": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "User task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string" }
      }
    },
    "LedgerItem": {
      "title": "Ledger Item",
      "description": "User transaction ledger on the market hub",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["inbound", "outbound"] },
        "value": { "type": "number" },
        "volume": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed", "pending"] },
        "operator": { "type": "string" }
      },
      "required": ["id", "description", "category", "type", "value", "volume", "total", "status", "operator"]
    },
    "Listing": {
      "title": "Listing",
      "description": "Marketplace item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "titleGe": { "type": "string" },
        "description": { "type": "string" },
        "descriptionGe": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "title", "price", "sellerId", "category", "country", "city"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "itemTitle": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "seller_reviews": {
      "title": "Seller Review",
      "description": "Ratings and reviews left by buyers for sellers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["sellerId", "buyerId", "rating", "text"]
    },
    "SharedSpec": {
      "title": "Shared Spec",
      "description": "Cached AI generated descriptions",
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Clip": {
      "title": "Proton Reel Clip",
      "description": "Short vertical video post shared by general users or marketplace sellers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoUrl": { "type": "string" },
        "caption": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "creatorAvatar": { "type": "string" },
        "likes": { "type": "array" },
        "likesCount": { "type": "number" },
        "soundName": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "videoUrl", "caption", "creatorId", "creatorName", "createdAt"]
    },
    "ClipComment": {
      "title": "Clip Comment",
      "description": "User comments on video clips",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clipId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "clipId", "userId", "userName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/clips/{clipId}": {
      "schema": "Clip",
      "description": "Global user-generated video reels / TikTok-style platform clips"
    },
    "/clips/{clipId}/comments/{commentId}": {
      "schema": "ClipComment",
      "description": "Subcollection of comments left on a specific video clip"
    },
    "/shared_specs/{specId}": {
      "schema": "SharedSpec",
      "description": "Global cache for AI specs"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Global marketplace listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global purchase records"
    },
    "/seller_reviews/{reviewId}": {
      "schema": "seller_reviews",
      "description": "Ratings and comments left for sellers by purchasers"
    },
    "/market_messages/{messageId}": {
      "schema": "object",
      "description": "Direct message chat between buyers and sellers"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user document"
    },
    "/users/{userId}/usage/{usageId}": {
      "schema": "object",
      "description": "User usage tracking (rate limits)"
    },
    "/users/{userId}/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "User workflows"
    },
    "/users/{userId}/personas/{personaId}": {
      "schema": "Persona",
      "description": "User personas"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/users/{userId}/market_ledger/{ledgerId}": {
      "schema": "LedgerItem",
      "description": "User market ledger transactions"
    },
    "/users/{userId}/chatHistory/{personaId}": {
      "schema": "object",
      "description": "Chat messages with a persona"
    }
  }
}
