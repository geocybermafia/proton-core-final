{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "ka"] }
      },
      "required": ["uid", "email"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "User automation workflows",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Persona": {
      "title": "Persona",
      "description": "AI Personality settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "systemInstruction": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "User task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string" }
      }
    },
    "Listing": {
      "title": "Listing",
      "description": "Marketplace item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "titleGe": { "type": "string" },
        "description": { "type": "string" },
        "descriptionGe": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "title", "price", "sellerId", "category", "country", "city"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "itemTitle": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "SharedSpec": {
      "title": "Shared Spec",
      "description": "Cached AI generated descriptions",
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/shared_specs/{specId}": {
      "schema": "SharedSpec",
      "description": "Global cache for AI specs"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Global marketplace listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global purchase records"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user document"
    },
    "/users/{userId}/usage/{usageId}": {
      "schema": "object",
      "description": "User usage tracking (rate limits)"
    },
    "/users/{userId}/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "User workflows"
    },
    "/users/{userId}/personas/{personaId}": {
      "schema": "Persona",
      "description": "User personas"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/users/{userId}/chatHistory/{personaId}": {
      "schema": "object",
      "description": "Chat messages with a persona"
    }
  }
}
