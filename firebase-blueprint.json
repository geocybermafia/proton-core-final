{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "ka"] },
        "notifications": { "type": "boolean" }
      },
      "required": ["name", "email", "language"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Operational metrics",
      "type": "object",
      "properties": {
        "storageGB": { "type": "number" },
        "workHours": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user document"
    },
    "/users/{userId}/stats/current": {
      "schema": "UserStats",
      "description": "User statistics"
    },
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Profile mirror"
    },
    "/users/{userId}/personas/{personaId}": {
      "schema": "Persona",
      "description": "User defined personas"
    }
  }
}
