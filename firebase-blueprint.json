{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "ka"] }
      },
      "required": ["uid", "email"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "User automation workflows",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Persona": {
      "title": "Persona",
      "description": "AI Personality settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "systemInstruction": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "User task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user document"
    },
    "/users/{userId}/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "User workflows"
    },
    "/users/{userId}/personas/{personaId}": {
      "schema": "Persona",
      "description": "User personas"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/users/{userId}/chatHistory/{personaId}": {
      "schema": "object",
      "description": "Chat messages with a persona"
    }
  }
}
