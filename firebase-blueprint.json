{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "Workflow definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "action": { "type": "string" },
        "personaId": { "type": "string" },
        "analysisHistory": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profile documents"
    },
    "/users/{userId}/workflows/{workflowId}": {
      "schema": { "$ref": "Workflow" },
      "description": "Workflow documents"
    }
  }
}
