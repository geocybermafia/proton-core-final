rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======================================================
    // 0. GLOBAL SAFETY NET
    // ======================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ======================================================
    // PHASE 3: PRIMITIVES
    // ======================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // In many production apps, email verification is required.
      // Keeping it commented or optional based on app context.
      // return isSignedIn() && request.auth.token.email_verified == true;
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ======================================================
    // ENTITY VALIDATORS (PILLAR 2)
    // ======================================================
    
    function isValidListingShape(data) {
      return (data.get('title', '') is string && data.get('title', '').size() <= 200)
        && (data.get('price', 0) is number && data.get('price', 0) >= 0)
        && (data.get('category', '') is string && data.get('category', '').size() <= 50)
        && (data.get('country', '') is string && data.get('country', '').size() <= 50)
        && (data.get('city', '') is string && data.get('city', '').size() <= 50)
        && (data.get('status', 'active') in ['active', 'sold'])
        && (data.get('description', '') is string && data.get('description', '').size() <= 5000)
        && (data.get('image', '') is string && data.get('image', '').size() <= 2000000); // Allow up to 2MB for base64
    }

    function isValidListingCreate(data) {
      return data.keys().hasAll(['title', 'price', 'sellerId', 'category', 'country', 'city', 'createdAt', 'status'])
        && data.keys().size() >= 8 && data.keys().size() <= 32
        && data.sellerId == request.auth.uid
        && data.createdAt == request.time
        && isValidListingShape(data);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['listingId', 'buyerId', 'sellerId', 'amount', 'currency', 'itemTitle', 'status', 'createdAt'])
        && data.keys().size() >= 8 && data.keys().size() <= 10
        && data.buyerId == request.auth.uid
        && data.listingId is string && data.listingId.size() <= 128
        && data.sellerId is string && data.sellerId.size() <= 128
        && data.amount is number && data.amount >= 0
        && data.currency is string && data.currency.size() <= 10
        && data.itemTitle is string && data.itemTitle.size() <= 200
        && data.status is string && data.status.size() <= 50
        && data.createdAt == request.time;
    }

    // ======================================================
    // 1. PROFILES & USERS
    // ======================================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /workflows/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /personas/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /chatHistory/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /tasks/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /market_ledger/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /customAvatars/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /stats/{id} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId && (
          id != "current" || 
          !('dailyGenerationsCount' in request.resource.data) || 
          request.resource.data.dailyGenerationsCount == null || 
          request.resource.data.dailyGenerationsCount <= 20
        );
      }
    }

    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /test/connection {
      allow get: if isSignedIn();
    }

    // ======================================================
    // 2. LISTINGS (PILLAR 3 & 8)
    // ======================================================
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(listingId) && isValidListingCreate(incoming());
      allow update: if isVerified() && isValidId(listingId) && (
        // Action: Edit by owner
        (isOwner(existing().sellerId) && isValidListingShape(incoming()) && incoming().sellerId == existing().sellerId) ||
        // Action: Mark as sold
        (isOwner(existing().sellerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Action: Self-healing / Claim restored listings globally
        (existing().sellerId == "rCWg6xJA2rfnnEWMbOFQdMJljxD3" && incoming().sellerId == request.auth.uid && isValidListingShape(incoming()))
      );
      allow delete: if isVerified() && isValidId(listingId) && isOwner(existing().sellerId);
    }

    // ======================================================
    // 3. ORDERS (NEW - PILLAR 8)
    // ======================================================
    match /orders/{orderId} {
      // Secure List Queries (Pillar 8)
      // Users can only see orders they bought or sold
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      
      allow create: if isVerified() && isValidId(orderId) && isValidOrder(incoming())
        // Relational Sync (Pillar 1/7) - Optional: verify listing exists and has correct price
        && exists(/databases/$(database)/documents/listings/$(incoming().listingId));
        
      allow update: if isVerified() && (existing().buyerId == request.auth.uid || existing().sellerId == request.auth.uid)
        && incoming().buyerId == existing().buyerId
        && incoming().sellerId == existing().sellerId
        && incoming().listingId == existing().listingId
        && incoming().amount == existing().amount
        && incoming().currency == existing().currency
        && incoming().itemTitle == existing().itemTitle
        && incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }

    // ======================================================
    // 6. SELLER REVIEWS & RATINGS (NEW - TRUST & SAFETY)
    // ======================================================
    match /seller_reviews/{reviewId} {
      allow read: if isSignedIn(); // Viewable only by logged-in users
      allow create: if isVerified() && isValidId(reviewId) 
        && incoming().buyerId == request.auth.uid 
        && incoming().sellerId != request.auth.uid 
        && incoming().rating is number 
        && incoming().rating >= 1 && incoming().rating <= 5 
        && incoming().text is string && incoming().text.size() <= 2000
        && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidId(reviewId) 
        && existing().buyerId == request.auth.uid 
        && incoming().buyerId == request.auth.uid 
        && incoming().sellerId == existing().sellerId 
        && incoming().rating is number 
        && incoming().rating >= 1 && incoming().rating <= 5 
        && incoming().text is string && incoming().text.size() <= 2000
        && incoming().createdAt == existing().createdAt;
      allow delete: if isVerified() && isValidId(reviewId) 
        && existing().buyerId == request.auth.uid;
    }

    // ======================================================
    // 7. CHAT MESSAGES BETWEEN TRADERS (NEW)
    // ======================================================
    match /market_messages/{messageId} {
      allow read, list: if isSignedIn() && (
        request.auth.uid in resource.data.get('participants', []) ||
        resource.data.get('senderId', '') == request.auth.uid || 
        resource.data.get('receiverId', '') == request.auth.uid || 
        resource.data.get('sellerId', '') == request.auth.uid
      );
      allow create: if isVerified() && isValidId(messageId) 
        && (incoming().get('senderId', '') == request.auth.uid || request.auth.uid in incoming().get('participants', []));
      allow update, delete: if false;
    }

    // ======================================================
    // 4. SYSTEM
    // ======================================================
    match /system/config {
      allow read: if true;
      allow write: if false; // Only via admin (not implemented here)
    }

    // ======================================================
    // 5. AI OPTIMIZATION (PILLAR 8)
    // ======================================================
    match /shared_specs/{specId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && incoming().spec is string && incoming().spec.size() <= 2000
        && incoming().createdAt == request.time;
    }

    match /users/{userId}/usage/ai {
      allow get: if isOwner(userId);
      allow write: if isOwner(userId)
        && incoming().lastAiGen == request.time;
    }
  }
}
