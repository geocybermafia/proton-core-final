rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // absolute default deny
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedOwner(userId) {
      return isSignedIn() && 
             request.auth.uid == userId && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'content', 'contentGe', 'completed']) &&
             data.id is string && data.id.size() <= 128 &&
             data.content is string && data.content.size() <= 5000 &&
             data.contentGe is string && data.contentGe.size() <= 5000 &&
             data.completed is bool;
    }

    match /neural_pulse/{pulseId} {
      allow list: if true;
      allow create: if isSignedIn() && 
                    isValidId(pulseId) && 
                    request.resource.data.projectTitle is string &&
                    request.resource.data.projectTitle.size() <= 200 &&
                    request.resource.data.createdAt == request.time;
    }

    match /test/connection {
      allow get: if true;
    }

    match /system/config {
      allow read: if true;
      allow write: if false; // Only manageable via Console or bootstrap logic
    }

    match /users/{userId} {
      // Allow the user to manage their own profile document
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      
      // Subcollections - Relaxed for persona sharing and collaborative chat
      match /personas/{personaId} {
        allow read, write: if isSignedIn();
      }
      
      match /workflows/{workflowId} {
        allow read, write: if isSignedIn();
      }
      
      match /customAvatars/{personaId} {
        allow read, write: if isSignedIn();
      }
      
      match /chatHistory/{personaId} {
        allow read, write: if isSignedIn();
      }

      match /tasks/{taskId} {
        allow list, get: if isVerifiedOwner(userId);
        allow create, update: if isVerifiedOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data);
        allow delete: if isVerifiedOwner(userId) && isValidId(taskId);
      }
    }
  }
}

