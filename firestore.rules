rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // absolute default deny
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedOwner(userId) {
      return isSignedIn() && 
             request.auth.uid == userId && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      // Allow the user to manage their own profile document
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      
      // Subcollections - Relaxed for persona sharing and collaborative chat
      match /personas/{personaId} {
        allow read, write: if isSignedIn();
      }
      
      match /workflows/{workflowId} {
        allow read, write: if isSignedIn();
      }
      
      match /customAvatars/{personaId} {
        allow read, write: if isSignedIn();
      }
      
      match /chatHistory/{personaId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}

